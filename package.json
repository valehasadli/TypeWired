{
  "name": "typewired",
  "version": "1.0.0",
  "description": "Fully type-safe dependency injection for TypeScript. Zero dependencies, no reflect-metadata, no decorators.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "bench": "node benchmarks/bench.mjs",
    "prepublishOnly": "yarn typecheck && yarn test && tsup"
  },
  "keywords": [
    "typescript",
    "dependency-injection",
    "di",
    "inversion-of-control",
    "ioc",
    "type-safe",
    "container",
    "scoped",
    "async"
  ],
  "author": "Valeh Asadli",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/valehasadli/typewired/issues"
  },
  "homepage": "https://github.com/valehasadli/typewired#readme",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "awilix": "^13.0.5",
    "jest": "^30.4.2",
    "reflect-metadata": "^0.2.2",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "tsyringe": "^4.10.0",
    "typescript": "^5"
  }
}
